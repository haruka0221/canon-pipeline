:58.676366"}}, {"publishers": ["Farrar, Straus and Giroux"], "lc_classifications": ["PZ3.H4525 G5", "PT2617.E85 G5"], "latest_revision": 3, "key": "/books/OL17758593M", "authors": [{"key": "/authors/OL76437A"}], "publish_places": ["New York"], "languages": [{"key": "/languages/eng"}], "pagination": "237 p.", "title": "Gertrude.", "dewey_decimal_class": ["833/.9/12"], "number_of_pages": 237, "created": {"type": "/type/datetime", "value": "2008-09-30T23:11:30.060957"}, "edition_name": "[Rev. translation]", "work_titles": ["Gertrud."], "last_modified": {"type": "/type/datetime", "value": "2011-11-04T19:56:44.903012"}, "publish_date": "1969", "publish_country": "nyu", "by_statement": "Translated by Hilda Rosner.", "works": [{"key": "/works/OL873092W"}], "type": {"key": "/type/edition"}, "revision": 3}, {"publishers": ["Farrar, Straus and Giroux"], "number_of_pages": 237, "ia_box_id": ["IA134907"], "covers": [9638127], "key": "/books/OL5682324M", "authors": [{"key": "/authors/OL76437A"}], "publish_places": ["New York"], "languages": [{"key": "/languages/eng"}, {"key": "/languages/ger"}], "pagination": "237 p.", "source_records": ["marc:marc_records_scriblio_net/part06.dat:115138612:560", "marc:marc_cca/b10621386.out:16925864:614", "marc:marc_ithaca_college/ic_marc.mrc:66753778:680", "ia:gertrude00hess", "marc:marc_openlibraries_phillipsacademy/PANO_FOR_IA_05072019.mrc:74877037:861", "marc:marc_loc_2016/BooksAll.2016.part07.utf8:15346840:555", "marc:marc_columbia/Columbia-extract-20221130-002.mrc:471164090:922", "marc:harvard_bibliographic_metadata/ab.bib.01.20150123.full.mrc:375306812:948", "marc:harvard_bibliographic_metadata/20220215_010.bib.mrc:214822311:2144"], "title": "Gertrude", "identifiers": {"librarything": ["2629406"]}, "edition_name": "[Rev. translation]", "local_id": ["urn:phillips:31867000151154"], "publish_date": "1969", "publish_country": "nyu", "by_statement": "Translated by Hilda Rosner.", "work_title": ["Gertrud."], "works": [{"key": "/works/OL873092W"}], "type": {"key": "/type/edition"}, "ocaid": "gertrude00hess", "lccn": ["69013738"], "classifications": {}, "dewey_decimal_class": ["833/.9/12"], "lc_classifications": ["PZ3.H4525 G5", "PT2617.E85 G5"], "oclc_numbers": ["4885"], "description": {"type": "/type/text", "value": "In this fictional memoir, the renowned composer Kuhn recounts his tangled relationships with two artists--his friend Heinrich Muoth, a brooding, self-destructive opera singer, and the gentle, self-assured Gertrude Imthor. Kuhn is drawn to Gertrude upon their first meeting, but Gertrude falls in love with Heinrich, to whom she is introduced when Kuhn auditions them for the leads in his new opera. Hopelessly ill-matched, Gertrude and Heinrich have a disastrous marriage that leaves them both ruined. Yet this tragic affair also becomes the inspiration for Kuhn's opera, the most important success of his artistic life."}, "latest_revision": 16, "revision": 16, "created": {"type": "/type/datetime", "value": "2008-04-01T03:28:50.625462"}, "last_modified": {"type": "/type/datetime", "value": "2025-07-20T11:38:32.767260"}}, {"identifiers": {"goodreads": ["1771049"], "librarything": ["2629406"]}, "title": "Gertrud.", "authors": [{"key": "/authors/OL76437A"}], "publish_date": "1973", "publishers": ["Rowohlt"], "languages": [{"key": "/languages/ger"}], "isbn_10": ["3499116642"], "publish_country": "gw ", "publish_places": ["Reinbek bei Hamburg"], "type": {"key": "/type/edition"}, "source_records": ["marc:talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:748760027:387"], "key": "/books/OL15267792M", "works": [{"key": "/works/OL873092W"}], "latest_revision": 5, "revision": 5, "created": {"type": "/type/datetime", "value": "2008-09-19T03:34:48.229267"}, "last_modified": {"type": "/type/datetime", "value": "2025-12-05T10:28:06.198503"}}, {"title": "Gertrude", "authors": [{"key": "/authors/OL76437A"}], "publish_date": "1969", "publishers": ["Farrar, Straus & Giroux"], "pagination": "237 p. ;", 