294, "source_records": ["marc:harvard_bibliographic_metadata/20220215_016.bib.mrc:283211332:1839"], "full_title": "\u00c0 rebours", "works": [{"key": "/works/OL2239396W"}], "key": "/books/OL60064820M", "latest_revision": 3, "revision": 3, "created": {"type": "/type/datetime", "value": "2025-09-05T23:04:05.863541"}, "last_modified": {"type": "/type/datetime", "value": "2025-12-05T20:06:36.641731"}}, {"type": {"key": "/type/edition"}, "publish_date": "1926", "publish_country": "fr", "languages": [{"key": "/languages/eng"}], "title": "Against the grain (A rebours)", "subtitle": "A novel without a plot", "authors": [{"key": "/authors/OL2658897A"}], "oclc_numbers": ["84256676"], "publishers": ["Librairie du Palais-royal"], "publish_places": ["Paris"], "pagination": "xxxi, 299 p.", "number_of_pages": 299, "source_records": ["marc:harvard_bibliographic_metadata/20220215_016.bib.mrc:318564610:627"], "full_title": "Against the grain (A rebours) A novel without a plot", "works": [{"key": "/works/OL2239396W"}], "key": "/books/OL60075600M", "latest_revision": 3, "revision": 3, "created": {"type": "/type/datetime", "value": "2025-09-07T09:20:57.094474"}, "last_modified": {"type": "/type/datetime", "value": "2025-12-05T20:06:36.641731"}}, {"type": {"key": "/type/edition"}, "isbn_10": ["146757886X"], "isbn_13": ["9781467578868"], "local_id": ["urn:bwbsku:P8-DAW-993"], "source_records": ["promise:bwb_daily_pallets_2023-04-12:P8-DAW-993", "standard_ebooks:j-k-huysmans/against-the-grain/groves-michaux", "bwb:9781467578868"], "title": "Against the Grain", "subtitle": "Liberal Notes from an Ultra Conservative County", "full_title": "Against the Grain Liberal Notes from an Ultra Conservative County", "works": [{"key": "/works/OL2239396W"}], "key": "/books/OL47697288M", "covers": [14634348], "description": {"type": "/type/text", "value": "<p>Ailing, neurotic, and bored with the world, the nobleman Des Esseintes retreats to a secluded cottage in the French countryside. Determined to shun all contact with other people\u2014demanding that even his live-in domestics must wear face-covering robes in his presence\u2014he throws himself into an all-out celebration of the ultimate in artificial and unnatural pleasure. Surrendering to religious and profane literature, morbid paintings, overwhelming perfumes, expensive liquor, grotesque flowers, and reminiscences of his depraved past brings him unsurpassable pleasure, but his mental and physical condition may not be able to keep up.</p> <p>When <a href=\"https://standardebooks.org/ebooks/j-k-huysmans\">Huysmans</a> wrote <i>Against the Grain</i>, he did so to move away from the creative restrictions he felt the Naturalist school of literature imposed on him. According to him, \u201cit limited itself to depicting common existence, and struggled, under the pretext of being true to life, to create characters who would be as close as possible to the average run of mankind.\u201d Instead, he dedicated Naturalism\u2019s attention to detail to just one extraordinary, perverse individual, Des Esseintes\u2014fully expecting the resulting work to fail critically and commercially.</p> <p>That the novel would become a scandalous success, and would define Decadence as a movement and ideology, was far beyond his expectations. <a href=\"https://standardebooks.org/ebooks/oscar-wilde\">Oscar Wilde</a> was a well-known admirer of the novel, and drew heavily from it to write <a href=\"https://standardebooks.org/ebooks/oscar-wilde/the-picture-of-dorian-gray\"><i>The Picture of Dorian Gray</i></a>. During his trial in 1895, Wilde all but confirmed that the \u201cpoisonous French novel\u201d in his work refers to <i>Against the Grain</i>.</p> <p>This Standard Ebooks edition is based on the first unabridged English edition, which was translated anonymously and published by Groves &amp; Michaux in 1926. It reinstates passages that were considered too obscene in previous editions, and includes a preface Huysmans wrote twenty years after the first publication of the book.</p>"}, "publishers": ["Standard Ebooks"], "publish_date": "2022", "identifiers": {"standard_ebooks": ["j-k-huysmans/against-the-grain/groves-michaux"]}, "latest_revision": 4, "revision": 4, "created": {"type": "/type/datetime", "value": "2023-05-04T01:54:43.084400"}, "last_modified": {"type": "/type/datetime", "value": "2025-12-05T20:06:36.641731"}}, {"title": "A\u0300 reburs", "authors": [{"key": "/authors/OL2658897A"}], "publish_date": "1978", "publishers": ["Flammarion"], "languages": [{"key": "/languages/fre"}], "publish_country": "fr ", "by_statement": "J.-K. Huysmans ; chronologie... par Pierre Waldner.", "publish_places": ["Paris"], "type": {"key": "/type/edition"}, "source_records": ["marc:talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:2974068339:419"], "key": "/books/OL20184160M", "works": [{"key": "/works/OL2239396W"}], "latest_revision": 6, "revision": 6, "created": {"type": "/type/datetime", "value": "2008-10-26T05:56:34.327036"}, "last_modified": {"type": "/type/datetime", "value": "2025-12-22T01:55:25.224018"}}, {"notes": {"type": "/type/text", "value": "6"}, "title": "Against the grain", "subtitle": "a rebours", "authors": [{"key": "/authors/OL2658897A"}], "by_statement": "translated by John Howard.", "publish_places": ["New York"], "type": {"key": "/type/edition"}, "source_records": ["marc:marc_laurentian/openlibrary.mrc:415245891:592"], "key": "/books/OL21436473M", "works": [{"key": "/works/OL2239396W"}], "latest_revision": 7, "revision": 7, "created": {"type": "/type/datetime", "value": "2008-11-02T14:45:13.026154"}, "last_modified": {"type": "/type/datetime", "value": "2025-12-18T15:13:28.198661"}}, {"identifiers": {"amazon": ["B08WJZC2VN"]}, "title": "\u00c0 Rebours (French Edition)", "type": {"key": "/type/edition"}, "local_id": ["urn:bwbsku:P7-EBI-510"], "source_records": ["promise:bwb_daily_pallets_2021-09-03"], "full_title": "\u00c0 Rebours (French Edition)", "key": "/books/OL43252942