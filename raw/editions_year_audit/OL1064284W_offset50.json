nguages/eng"}], "number_of_pages": 206, "publish_date": "2024", "publishers": ["Mixtpublish"], "source_records": ["bwb:9781803986289"], "title": "Ars\u00e8ne Lupin Versus Herlock Sholmes", "weight": "0.282", "full_title": "Ars\u00e8ne Lupin Versus Herlock Sholmes", "works": [{"key": "/works/OL1064284W"}], "key": "/books/OL56897609M", "latest_revision": 2, "revision": 2, "created": {"type": "/type/datetime", "value": "2024-10-06T05:14:50.805457"}, "last_modified": {"type": "/type/datetime", "value": "2025-11-15T18:22:26.145874"}}, {"type": {"key": "/type/edition"}, "authors": [{"key": "/authors/OL2660342A"}], "isbn_13": ["9798745764875"], "languages": [{"key": "/languages/eng"}], "pagination": "130", "publish_date": "2021", "publishers": ["Independently Published"], "source_records": ["bwb:9798745764875"], "title": "Ars\u00e8ne Lupin Versus Herlock Sholmes", "weight": "0.250", "subtitle": "Translated by George Morehead", "full_title": "Ars\u00e8ne Lupin Versus Herlock Sholmes Translated by George Morehead", "works": [{"key": "/works/OL1064284W"}], "key": "/books/OL36984224M", "latest_revision": 3, "revision": 3, "created": {"type": "/type/datetime", "value": "2022-01-29T12:17:16.349629"}, "last_modified": {"type": "/type/datetime", "value": "2025-11-15T18:22:26.145874"}}, {"type": {"key": "/type/edition"}, "authors": [{"key": "/authors/OL2660342A"}], "description": {"type": "/type/text", "value": "<p><a href=\"https://standardebooks.org/collections/arsene-lupin\">Ars\u00e8ne Lupin</a> takes on his most fearsome opponent yet in this second collection of his larcenous adventures. More a loving homage than a straight copy, Herlock Sholmes (changed just enough to avoid fallout from a copyright claim by <a href=\"https://standardebooks.org/ebooks/arthur-conan-doyle\">Conan Doyle</a>) and his companion Wilson are summoned to France initially to throw light on the case of the Blonde Lady. Having encountered Ars\u00e8ne Lupin before, Sholmes is only too happy to get a chance of revenge.</p>\r\n\t\t\t<p>This collection of two stories were originally serialised in the magazine <i>Je Sais Tout</i> from 1906 to 1907, and were translated into English in 1910. After an earlier story with an unauthorised <a href=\"https://standardebooks.org/collections/sherlock-holmes\">Sherlock Holmes</a>, <a href=\"https://standardebooks.org/ebooks/maurice-leblanc\">Maurice Leblanc</a> was forced to rename his antagonist for these stories.</p>"}, "identifiers": {"standard_ebooks": ["maurice-leblanc/arsene-lupin-versus-herlock-sholmes/george-morehead"]}, "languages": [{"key": "/languages/eng"}], "publish_date": "2018", "publishers": ["Standard Ebooks"], "source_records": ["standard_ebooks:maurice-leblanc/arsene-lupin-versus-herlock-sholmes/george-morehead"], "subjects": ["Burglars -- Fiction", "Lupin, Ars\u00e8ne (Fictitious character) -- Fiction", "Adventure stories, French -- Translations into English", "Doyle, Arthur Conan, Sir, 1859-1930 -- Parodies, imitations, etc."], "title": "Ars\u00e8ne Lupin Versus Herlock Sholmes", "full_title": "Ars\u00e8ne Lupin Versus Herlock Sholmes", "covers": [12621880], "works": [{"key": "/works/OL1064284W"}], "key": "/books/OL37044607M", "latest_revision": 4, "revision": 4, "created": {"type": "/type/datetime", "value": "2022-02-08T23:55:11.197321"}, "last_modified": {"type": "/type/datetime", "value": "2026-01-08T11:35:52.403840"}}, {"type": {"key": "/type/edition"}, "authors": [{"key": "/authors/OL2660342A"}, {"key": "/authors/OL1483469A"}], "isbn_13": ["9781497679801"], "languages": [{"key": "/languages/eng"}], "pagination": "240", "publish_date": "2014", "publishers": ["MysteriousPress.com"], "source_records": ["bwb:9781497679801"], "title": "Ars\u00e8ne Lupin Versus Herlock Sholmes", "full_title": "Ars\u00e8ne Lupin Versus Herlock Sholmes", "works": [{"key": "/works/OL1064284W"}], "key": "/books/OL37413469M", "contributors": [{"role": "Introduction", "name": "Otto Penzler"}], "latest_revision": 4, "revision": 4, "crea