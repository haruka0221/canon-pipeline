{"links": {"self": "/works/OL15309606W/editions.json?limit=50", "work": "/works/OL15309606W"}, "size": 10, "entries": [{"publishers": ["Alfred A. Knopf"], "classifications": {}, "title": "Cautionary tales for children", "identifiers": {}, "covers": [10029710], "created": {"type": "/type/datetime", "value": "2015-11-11T04:31:45.445110"}, "latest_revision": 3, "last_modified": {"type": "/type/datetime", "value": "2020-05-22T23:03:27.204253"}, "publish_date": "1922", "key": "/books/OL25839335M", "ocaid": "CautionaryTalesForChildren", "subtitle": "designed for the admonition of children between the ages of eight and fourteen years", "publish_places": ["New York, USA"], "works": [{"key": "/works/OL15309606W"}], "type": {"key": "/type/edition"}, "oclc_numbers": ["362147"], "revision": 3}, {"title": "Cautionary tales for children", "authors": [{"key": "/authors/OL266207A"}], "publish_date": "1918", "publishers": ["Gerald Duckworth & Co."], "contributions": ["B.T.B."], "languages": [{"key": "/languages/eng"}], "publish_country": "xxk", "by_statement": "pictures by B.T.B.", "publish_places": ["s.l"], "type": {"key": "/type/edition"}, "source_records": ["marc:talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:211352603:428"], "key": "/books/OL13874889M", "works": [{"key": "/works/OL15309606W"}], "latest_revision": 4, "revision": 4, "created": {"type": "/type/datetime", "value": "2008-09-01T22:25:14.513551"}, "last_modified": {"type": "/type/datetime", "value": "2026-02-02T19:47:51.268405"}}, {"publishers": ["Harcourt"], "ia_box_id": ["IA183401"], "isbn_10": ["0151007152"], "dewey_decimal_class": ["821/.912"], "pagination": "1 v. (unpaged) :", "covers": [112256], "ia_loaded_id": ["cautionarytalesf00bell_0"], "lc_classifications": ["PR6003.E45 C34 2002", "PR6003.E45C34 2002"], "key": "/books/OL3554267M", "authors": [{"key": "/authors/OL266207A"}], "publish_places": ["New York"], "contributions": ["Gorey, Edward, 1925-"], "uri_descriptions": ["Contributor biographical information", "Publisher description"], "languages": [{"key": "/languages/eng"}], "genres": ["Juvenile poetry."], "source_records": ["ia:cautionarytalesf00bell_0", "bwb:9780151007158", "marc:marc_loc_2016/BooksAll.2016.part29.utf8:171531469:921", "marc:marc_columbia/Columbia-extract-20221130-018.mrc:35066823:3032", "ia:cautionarytalesf0000bell", "marc:harvard_bibliographic_metadata/20220215_025.bib.mrc:350042931:4227"], "title": "Cautionary tales for children", "lccn": ["2002007963"], "identifiers": {"librarything": ["45531"], "goodreads": ["47561"]}, "edition_name": "1st ed.", "url": ["http://www.loc.gov/catdir/bios/har051/2002007963.html", "http://www.loc.gov/catdir/description/har021/2002007963.html"], "subjects": ["Conduct of life -- Juvenile poetry.", "Children's poetry, English."], "publish_date": "2002", "publish_country": "nyu", "by_statement": "Hilaire Belloc ; rediscovered and illustrated by Edward Gorey.", "oclc_numbers": ["49922329"], "works": [{"key": "/works/OL15309606W"}], "type": {"key": "/type/edition"}, "uris": ["http://www.loc.gov/catdir/bios/har051/2002007963.html", "http://www.loc.gov/catdir/description/har021/2002007963.html"], "ocaid": "cautionarytalesf0000bell", "description": {"type": "/type/text", "value": "From the Publisher: One of Hilaire Belloc's most famous works, \"Cautionary Tales for Children\" satirizes a genre of admonitory children's literature popular in England in the late 18th and 19th centuries. The seven stories contained in this work are macabre parodies of childhood lessons, and will entertain more sophisticated readers who can appreciate these tales of disproportionate punishment. Presented in a classic picture book style, illustrators have captured the foibles of children like Jim, who let go of his nurse's hand and was eaten by a lion; Matilda, who told lies, and was burned to death; and Henry King who swallowed string. The consequences range from naughty children being whimsically eaten by lions, to stern reprimands for a boy who fires a loaded gun at his sister. Originally written nearly a century ago, Belloc's sprightly verses are a quick and cathartic read for teenagers, and reflect a trend of literature that is still popular today."}, "latest_revision": 15, "revision": 15, "created": {"type": "/type/datetime", "value": "2008-04-01T03:28:50.625462"}, "last_modified": {"type": "/type/datetime", "value": "2026-01-03T04:06:03.258007"}}, {"publishers": ["Duckworth"], "subtitle": "designed for the adomition of children between the ages of eight and fourteen years", "title": "Cautionary tales for children", "contributions": ["B.T.B."], "created": {"type": "/type/datetime", "value": "2008-09-02T11:36:20.371978"}, "edition_name": "New ed.", "languages": [{"key": "/languages/eng"}], "last_modified": {"type": "/type/datetime", "value": "2010-08-12T18:22:11.496505"}, "publish_date": "1918", "publish_country": "xxk", "key": "/books/OL13984136M", "authors": [{"key": "/authors/OL266207A"}], "by_statement": "pictures by B.T.B. [i.e. Lord Basil Blackwood].", "publish_places": ["London"], "works": [{"key": "/works/OL15309606W"}], "type": {"key": "/type/edition"}, "latest_revision": 3, "revision": 3}, {"identifiers": {"goodreads": ["1617949"]}, "title": "Cautionary Tales for Children", "authors": [{"key": "/authors/OL266207A"}], "publish_date": "October 1985", "publishers": ["Holiday House"], "physical_format": "School & Library Binding", "isbn_13": ["9780823405299"], "languages": [{"key": "/languages/eng"}], "isbn_10": ["082340529X"], "oclc_numbers": ["10482966"], "type": {"key": "/type/edition"}, "subjects": ["Children's poetry, English", "Children: Babies & Toddlers", "Conduct of life", "Children", "Juvenile poetry", "Nonsense verses"], "first_sentence": {"type": "/type/text", "value": "There was a Boy whose name was Jim;"}, "source_records": ["amazon:082340529X"], "key": "/books/OL9872315M", "works": [{"key": "/works/OL15309606W"}], "latest_revision": 7, "revision": 7, "created": {"typ