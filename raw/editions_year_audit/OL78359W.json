"/type/datetime", "value": "2008-09-28T08:27:54.965095"}, "last_modified": {"type": "/type/datetime", "value": "2023-12-24T12:40:33.210501"}}, {"publishers": ["The Blakiston Company"], "identifiers": {"goodreads": ["15834636"], "librarything": ["1475"]}, "subtitle": "A Novel", "weight": "1 pounds", "covers": [14559654], "physical_format": "Hardcover", "key": "/books/OL28125005M", "publish_places": ["Philadelphia, USA"], "pagination": "376p. [unnmb: 8p.fr/4p.bk]", "classifications": {}, "title": "A Tree Grows in Brooklyn", "notes": "***Manufactured in the U.S.A.* This edition made by special arrangement with *Harper & Brothers***", "number_of_pages": 376, "languages": [{"key": "/languages/eng"}], "publish_date": "1943", "copyright_date": "1943 by Betty Smith", "by_statement": "A Novel by Betty Smith", "works": [{"key": "/works/OL78359W"}], "type": {"key": "/type/edition"}, "physical_dimensions": "8 x 5.5 x 1 inches", "lccn": ["43012149"], "oclc_numbers": ["855267305", "986772"], "ocaid": "treegrowsinbrook0000smit_c2d5", "lc_classifications": ["PS3537.M2895 T7 1943"], "source_records": ["ia:treegrowsinbrook0000smit_c2d5"], "latest_revision": 8, "revision": 8, "created": {"type": "/type/datetime", "value": "2020-05-21T20:40:35.939531"}, "last_modified": {"type": "/type/datetime", "value": "2025-05-14T04:37:09.354475"}}, {"publishers": ["Harper & Brothers Publishers"], "identifiers": {"goodreads": ["3426929"], "librarything": ["1475"]}, "subtitle": "A Novel", "description": {"type": "/type/text", "value": "A huge bestseller which went through innumerable printings. Basis for the first film directed by Elia Kazan, which featured Dorothy McGuire, Joan Blondell, and Oscar winners Peggy Ann Garner and James Dunn (who touchingly brought his considerable experience as a real alcoholic to the screen).--Biblio\r\n\r\nFrancie Nolan, avid reader, penny-candy connoisseur, and adroit observer of human nature, has much to ponder in colorful, turn-of-the-century Brooklyn. She grows up with a sweet, tragic father, a severely realistic mother, and an aunt who gives her love too freely--to men, and to a brother who will always be the favored child. Francie learns early the meaning of hunger and the value of a penny. She is her father's child--romantic and hungry for beauty. But she is her mother's child, too--deeply practical and in constant need of truth. Like the Tree of Heaven that grows out of cement or through cellar gratings, resourceful Francie struggles against all odds to survive and thrive.\r\n\r\nBetty Smith's poignant, honest novel created a big stir when it was first published... --Emilie Coulter at Amazon.com. \"Maggie Now\": This book begins its story before Maggie Now's birth. It introduces her contrary father, Patrick, as a young man in Ireland and her gentle mother, Mary, as a school teacher in New York at the turn of the century. They meet in New York after Patrick flees Ireland and comes to America to work for Mary's father. Maggie Now grows up attending Catholic school, rearing her younger brother and yearning for love and a family of her own.-- Aurora"}, "covers": [10197859], "physical_format": "Hardcover", "lc_classifications": ["PS3537.M2895 T7 1943"], "key": "/books/OL28270162M", "publish_places": ["New York, USA"], "languages": [{"key": "/languages/enm"}], "pagination": "443p., [6p.fr/3p.bk", "classifications": {}, "source_records": ["marc:marc_loc_2016/BooksAll.2016.part04.utf8:29031297:736", "marc:marc_columbia/Columbia-extract-20221130-013.mrc:163206978:792"], "title": "A Tree Grows in Brooklyn", "lccn": ["43012149"], "notes": {"type": "/type/text", "value": "***Manufactured in the U.S.A.*** / First ed. 145 [i.e. 290] leaves; Bound galley proof; SpecCol. c.1 has bookplate: \"Ex libris Mary E. Hemenway;\" Related names: Herman Finkelstein Collection (Library of Congress); OCLC 639466728 / ***Although this 1st ed is from a pre-ISBN period, it appears (see 1st ed Biblio) to have been given an ISBN, one noted in several web addresses, including goodreads.***"}, "number_of_pages": 443, "isbn_13": ["9780965025546"], "edition_name": "2nd Harper ed - 1st (?)", "isbn_10": ["0965025543"], "publish_date": "1943", "copyright_date": "1943", "by_statement": "A Novel by Betty Smith", "oclc_numbers": ["20029079", "1343358"], "works": [{"key": "/works/OL78359W"}], "type": {"key": "/type/edition"}, "physical_dimensions": "8 x 5.63 x 1.25 inches", "latest_revision": 6, "revision": 6, "created": {"type": "/type/datetime", "value": "2020-06-18T18:54:09.180069"}, "last_modified": {"type": "/type/datetime", "value": "2023-12-24T12:34:17.973401"}}, {"publishers": ["Blakiston"], "pagination": "376 p. ;", "subtitle": "a novel", "title": "A tree grows in Brooklyn", "series": ["Jackson collection"], "number_of_pages": 376, "languages": [{"key": "/languages/eng"}], "subjects": ["Fiction"], "publish_date": "1943", "publish_country": "pau", "key": "/books/OL16171409M", "authors": [{"key": "/authors/OL39597A"}], "by_statement": "by Betty Smith.", "publish_places": ["Philadelphia"], "type": {"key": "/type/edition"}, "works": [{"key": "/works/OL78359W"}], "identifiers": {}, "ocaid": "isbn_B008VIPEU4", "classifications": {}, "covers": [14559629], "latest_revision": 9, "revision": 9, "created": {"type": "/type/datetime", "value": "2008-09-22T11:28:43.618965"}, "last_modified": {"type": "/type/datetime", "value": "2023-12-24T12:40:33.210501"}}, {"works": [{"key": "/works/OL78359W"}], "title": "A tree grows in Brooklyn", "publishers": ["Harper & Row"], "publish_date": "1973", "key": "/books/OL50521966M", "type": {"key": "/type/edition"}, "identifiers": {}, "classifications": {}, "languages": [{"key": "/languages/eng"}], "isbn_10": ["0060801263"], "ocaid": "treegrowsinbrook0000smit_u0w0", "covers": [14559634], "latest_revision": 5, "revision": 5, "created": {"type": "/type/datetime", "value": "2023-12-24T10:32:09.789865"}, "last_modified": {"type": "/type/datetime", "value": "2023-12-24T12:34:17.973401"}}]}