: ["New York"], "lccn": ["96024304"], "uri_descriptions": ["Contributor biographical information", "Publisher description"], "edition_name": "1st Scribner pbk. fiction ed.", "genres": ["Fiction."], "source_records": ["marc:marc_records_scriblio_net/part25.dat:185355786:1019", "ia:mothersrecompens00whar_0", "marc:marc_loc_2016/BooksAll.2016.part25.utf8:91312916:1110", "bwb:9780684825311", "marc:marc_columbia/Columbia-extract-20221130-004.mrc:511576001:1585"], "title": "The mother's recompense", "url": ["http://www.loc.gov/catdir/bios/simon051/96024304.html", "http://www.loc.gov/catdir/description/simon033/96024304.html"], "number_of_pages": 272, "languages": [{"key": "/languages/eng"}], "dewey_decimal_class": ["813/.52"], "subjects": ["Mothers and daughters -- Fiction", "New York (N.Y.) -- Fiction", "Riviera (France) -- Fiction"], "publish_date": "1996", "publish_country": "nyu", "by_statement": "Edith Wharton ; introduction by Louis Auchincloss.", "works": [{"key": "/works/OL98563W"}], "type": {"key": "/type/edition"}, "uris": ["http://www.loc.gov/catdir/bios/simon051/96024304.html", "http://www.loc.gov/catdir/description/simon033/96024304.html"], "oclc_numbers": ["34958704"], "description": {"type": "/type/text", "value": "Opening on the French Riviera among a motley community of American expatriates, The Mother's Recompense tells the story of Kate Clephane and her reluctant return to New York society after being exiled years before for abandoning her husband and infant daughter.\n\nOddly enough, Kate has been summoned back by that same daughter, Anne, now fully grown and intent on marrying Chris Fenno, a war hero, dilettante, and social opportunist. Chris' questionable intentions toward her daughter are, however, the least of Kate's worries since she was once, and still is, deeply in love with him. Kate's moral quandary and the ensuing drama evoke comparison with Oedipus and Hamlet and lead to an ending that startled the mores of the day."}, "latest_revision": 14, "revision": 14, "created": {"type": "/type/datetime", "value": "2008-04-01T03:28:50.625462"}, "last_modified": {"type": "/type/datetime", "value": "2024-08-04T06:29:02.756940"}}, {"publishers": ["Grosset & Dunlap"], "last_modified": {"type": "/type/datetime", "value": "2011-10-17T21:44:56.951473"}, "latest_revision": 4, "key": "/books/OL16507514M", "authors": [{"key": "/authors/OL20188A"}], "publish_places": ["[New York]"], "oclc_number": ["6082207"], "pagination": "341 p. ;", "revision": 4, "source_records": ["marc:bcl_marc/bcl_open.01.mrc:364870687:671"], "title": "The mother's recompense", "number_of_pages": 341, "created": {"type": "/type/datetime", "value": "2008-09-24T10:20:48.632849"}, "languages": [{"key": "/languages/eng"}], "publish_date": "1925", "publish_country": "xx ", "by_statement": "by Edith Wharton.", "works": [{"key": "/works/OL98563W"}], "type": {"key": "/type/edition"}, "location": ["MChB"]}, {"publishers": ["Virago"], "number_of_pages": 353, "series": ["Virago modern classics -- no.217"], "key": "/books/OL18237825M", "authors": [{"key": "/authors/OL20188A"}], "publish_places": ["London"], "pagination": "353p. ;", "source_records": ["marc:talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:1755433642:729", "bwb:9780860684114"], "title": "The mother's recompense", "dewey_decimal_class": ["813/.4"], "notes": {"type": "/type/text", "value": "First published New York, D. Appleton and Company, 1925."}, "identifiers": {"goodreads": ["6549450"], "librarything": ["81131"]}, "languages": [{"key": "/languages/eng"}], "isbn_10": ["0860684113"], "publish_date": "1986", "publish_country": "xxk", "by_statement": "Edith Wharton ; with a new afterword by Marilyn French.", "works": [{"key": "/works/OL98563W"}], "type": {"key": "/type/edition"}, "latest_revision": 7, "revision": 7, "created": {"type": "/type/datetime", "value": "2008-10-15T07:58:28.746582"}, "last_modified": {"type": "/type/datetime", "value": "2021-09-15T17:54:08.349267"}}, {"publ