tetime", "value": "2008-04-01T03:28:50.625462"}, "last_modified": {"type": "/type/datetime", "value": "2026-02-09T22:31:47.805067"}}, {"identifiers": {"goodreads": ["1713827"], "librarything": ["7574"]}, "title": "Hornblower & the Atropos", "authors": [{"key": "/authors/OL232499A"}], "publish_date": "January 2002", "publishers": ["Little Brown and Company"], "languages": [{"key": "/languages/eng"}], "isbn_13": ["9780316192255"], "physical_format": "Paperback", "isbn_10": ["0316192252"], "type": {"key": "/type/edition"}, "subjects": ["General", "Fiction", "Fiction - General"], "source_records": ["amazon:0316192252"], "key": "/books/OL10427006M", "works": [{"key": "/works/OL1937666W"}], "latest_revision": 7, "revision": 7, "created": {"type": "/type/datetime", "value": "2008-04-30T09:38:13.731961"}, "last_modified": {"type": "/type/datetime", "value": "2026-02-09T22:31:47.805067"}}, {"publishers": ["Sphere"], "number_of_pages": 284, "isbn_10": ["0722105096"], "key": "/books/OL21500280M", "authors": [{"key": "/authors/OL232499A"}], "publish_places": ["London"], "pagination": "284p. ;", "title": "Hornblower and the 'Atropos'.", "dewey_decimal_class": ["823/.9/1F"], "notes": {"type": "/type/text", "value": "Originally published: London : Joseph, 1953."}, "identifiers": {"librarything": ["7574"], "goodreads": ["3353861"]}, "languages": [{"key": "/languages/eng"}], "subjects": ["Fiction in English."], "publish_date": "1980", "publish_country": "xxk", "oclc_numbers": ["16496331"], "works": [{"key": "/works/OL1937666W"}], "type": {"key": "/type/edition"}, "source_records": ["bwb:9780722105092"], "latest_revision": 7, "revision": 7, "created": {"type": "/type/datetime", "value": "2008-11-02T20:51:45.618109"}, "last_modified": {"type": "/type/datetime", "value": "2026-02-09T22:31:47.805067"}}, {"publishers": ["Amereon Limited"], "weight": "1.2 pounds", "first_sentence": {"type": "/type/text", "value": "HAVING CLIMBED through the locks, the canal boat was now winding over the pleasant Cotswold country."}, "series": ["Horatio Hornblower (5)"], "physical_format": "Hardcover", "key": "/books/OL8258171M", "authors": [{"key": "/authors/OL232499A"}], "subjects": ["General", "Fiction - General"], "languages": [{"key": "/languages/eng"}], "classifications": {}, "title": "Hornblower and the Atropos (Hornblower Saga", "notes": {"type": "/type/text", "value": "Hardcover"}, "identifiers": {"librarything": ["7574"]}, "isbn_13": ["9780848804879"], "isbn_10": ["0848804872"], "publish_date": "October 1976", "oclc_numbers": ["608853483"], "works": [{"key": "/works/OL1937666W"}], "type": {"key": "/type/edition"}, "physical_dimensions": "8.8 x 5.7 x 1 inches", "source_records": ["bwb:9780848804879"], "latest_revision": 7, "revision": 7, "created": {"type": "/type/datetime", "value": "2008-04-29T15:03:11.581851"}, "last_modified": {"type": "/type/datetime", "value": "2026-02-09T22:31:47.805067"}}, {"publishers": ["Pinnacle Books"], "description": "Here is the fourth exciting novel in the world-acclaimed saga of Horatio Hornblower, the most famous naval hero in all fiction. He's a captain now, in command of HMS Atropos, a sloop of war, admittedly the smallest ship in the British navy, but as fast and responsive as even Hornblower could ask.\r\nIt is 1806, and the British have destroyed the French and Spanish fleets in the Atlantic. Now the navy is carrying its might into the Mediterranean, to head off any moves that Bonaparte \u2014 who is in command of Continental Europe \u2014 might make there. It is to be the French army versus the Royal Navy. And Hornblower plays a thrilling and important role in the conflict.\r\nBut first he must supervise the funeral of Lord Nelson, lead a search for buried treasure in Turkish waters, and fight a gallant battle with a Spanish frigate that far outguns the Atropos...", "series": ["Horatio Hornblower N\u00ba 4"], "covers": [6279926], "physical_format": "Paperback", "key": "/books/OL23978348M", "authors": [{"key": "/authors/OL232499A"}], "publish_places": ["New York"], "languages": [{"key": "/languages/eng"}], "genres": ["Novel; Fiction; Adventures"], "first_sentence": "HAVING CLIMBED up through the locks, the canal boat was now winding over the pleasant Cotswold country. Hornblower was bubbling with good spirits, on his way to take up a new command, seeing new sights, travelling in an entirely new way, at a moment when the entirely unpredictable English weather had decided to stage a clear sunny day in the middle of December. This was a delightful way of travelling, despite the cold.\r\n\"Your pardon for a moment, ma'am,\" said Hornblower.\r\nMaria, with the sleeping little Horatio in her arms, gave a sigh at her husband's restlessness and shifted her knees to allow him passage, and he rose under the restricted height of the first-class cabin and stepped out through the forward door into the open bow of the passage boat. Here he could stand on his sea-chest and look round him. She was a queer craft, fully seventy feet long and, judging by eye as he looked aft, he would think hardly five feet in beam\u2014the same proportions as had the crazy dugout canoes he had seen in use in the West Indies. Her draught must be less than a foot; that was clear as she tore along behind the cantering horses at a speed that must certainly be all of eight knots\u2014nine miles an hour he told himself, hurriedly, for that was the way they measured speeds here inland.\r\nThe passage boat was making her way from Gloucester to London along the Thames and Severn Canal; going far more smoothly than the stage coach, it was very nearly as...", "title": "Hornblower and the Atropos", "notes": "\"Hornblower has made his way into the public heart as few fictional heroes have ever done.\"\r\n\u2014The San Francisco Chronicle.", "number_of_pages": 313, "edition_name": "Third", "subjects": ["Historical Fiction"], "publish_date": "1977", "by_statement": "C. S. Forester", "type": {"key": "/type/edition"}, "physical_dimensions": "10,5x17 cm", "identifiers": {}, "isbn_10": ["0523003846"], "works": [{"key": "/works/OL1937666W"}], "latest_revision": 6, "revision": 6, "created": {"type": "/type/datetime", "value": "2009-12-23T17:54:18.159801"}, "last_modified": {"type": "/type/datetime", "value": "2026-02-08T15:26:31.013357"}}, {"publishers": ["Pinnacle Books"], "languages": [{"key": "/languages/eng"}], "identifiers": {"goodreads": ["84752"], "librarything": ["7574"]}, "title": "Hornblower and the Atropos (The Hornblower Saga, #4)", "physical_format": "Mass Market Paperback", "number_of_pages": 310, "edition_name": "3rd Printing edition", "publish_date": "1977", "key": "/books/OL7768584M", "type": {"key": "/type/edition"}, "isbn_10": ["0523003846"], "isbn_13": ["9780523003849"], "works": [{"key": "/works/OL1937666W"}], "latest_revision": 4, "revision": 4, "created": {"type": "/type/datetime", "value": "2008-04-29T15:03:11.581851"}, "last_modified": {"type": "/type/datetime", "value": "2026-02-08T15:26:17.094939"}}, {"identifiers": {"goodreads": ["2398261"], "librarything": ["7574"]}, "title": "Hornblower And The Atropos", "authors": [{"key": "/authors/OL232499A"}], "publish_date": "July 1975", "publishers": ["Pinnacle Books"], "series": ["Horatio Hornblower (5)"], "physical_format": "Mass Market Paperback", "subjects": ["Espionage/Intrigue", "Fiction - Espionage / Thriller"], "edition_name": "Reissue edition", "languages": [{"key": "/languages/eng"}], "type": {"key": "/type/edition"}, "first_sentence": "HAVING CLIMBED through the locks, the canal boat was now winding over the pleasant Cotswold country.", "source_records": ["bwb:9780523413891", "promise:bwb_daily_pallets_2022-08-30"], "local_id": ["urn:bwbsku:W7-COS-824"], "key": "/books/OL7769085M", "works": [{"key": "/works/OL1937666W"}], "ocaid": "hornblower04atro0000csfo", "isbn_10": ["0523413890"], "isbn_13": ["9780523413891"], "classifications": {}, "latest_revision": 9, "revision": 9, "created": {"type": "/type/datetime", "value": "2008-04-29T15:03:11.581851"}, "last_modified": {"type": "/type/datetime", "value": "2024-10-07T17:32:22.752359"}}]}