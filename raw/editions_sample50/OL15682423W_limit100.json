aris]"], "oclc_number": ["4099543"], "pagination": "502 p. ;", "title": "Mort \u00e0 cr\u00e9dit", "number_of_pages": 502, "languages": [{"key": "/languages/fre"}], "publish_date": "1952", "publish_country": "fr ", "by_statement": "Louis Ferdinand C\u00e9line [i.e. Louis Ferdinand Destouches]", "works": [{"key": "/works/OL15682423W"}], "type": {"key": "/type/edition"}, "location": ["MChB"], "latest_revision": 6, "revision": 6, "created": {"type": "/type/datetime", "value": "2008-09-24T16:16:52.616047"}, "last_modified": {"type": "/type/datetime", "value": "2023-04-16T13:13:07.560352"}}, {"publishers": ["New Directions Pub. Corp."], "identifiers": {"goodreads": ["106096"], "librarything": ["8421"]}, "isbn_10": ["0811200175"], "series": ["A New Directions book"], "key": "/books/OL18192550M", "authors": [{"key": "/authors/OL2781391A"}], "publish_places": ["New York"], "pagination": "xi, 592 p. ;", "source_records": ["marc:marc_openlibraries_sanfranciscopubliclibrary/sfpl_chq_2018_12_24_run06.mrc:70387328:2778", "ia:deathoninstallme0000clin", "bwb:9780811200172", "marc:marc_columbia/Columbia-extract-20221130-001.mrc:382617163:1303", "marc:harvard_bibliographic_metadata/20220215_009.bib.mrc:16490681:2126"], "title": "Death on the installment plan", "lccn": ["11648161", "66018692"], "notes": {"type": "/type/text", "value": "Translation of Mort a\u0300 cre\u0301dit."}, "number_of_pages": 592, "languages": [{"key": "/languages/eng"}], "local_id": ["urn:sfpl:31223129515533", "urn:sfpl:31223129515558", "urn:sfpl:31223129515541", "urn:sfpl:31223129515525"], "publish_date": "1971", "publish_country": "nyu", "by_statement": "by Louis-Ferdinand Ce\u0301line; translated from the French by Ralph Manheim.", "works": [{"key": "/works/OL15682423W"}], "type": {"key": "/type/edition"}, "covers": [10654328], "ocaid": "deathoninstallme0000clin", "lc_classifications": ["PZ3.D475 De4", "PQ2607.E834 M813 1971", "PQ2607.E834"], "oclc_numbers": ["341849", "11648161"], "description": {"type": "/type/text", "value": "Death on the Installment Plan is a companion volume to Louis-Ferinand C\u00e9line's earlier novel Journey to the End of Night. Published in rapid succession in the middle 1930s, these two books shocked European literatue and world consciousness. Nominally fiction but more rightly called \"creative confessions,\" they told of the author's childhood in excoriating Paris slums, of serves in the mud wastes of World War I and African jungles. Mixing unmitigated despair with Gargantuan comedy, they also created a new style, in which invective and obscenity were laced with phrases of unforgettable poetry."}, "latest_revision": 12, "revision": 12, "created": {"type": "/type/datetime", "value": "2008-10-11T20:46:55.121342"}, "last_modified": {"type": "/type/datetime", "value": "2025-06-09T15:29:12.941835"}}]}