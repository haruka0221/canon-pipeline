{"links": {"self": "/works/OL1798912W/editions.json?limit=100", "work": "/works/OL1798912W"}, "size": 46, "entries": [{"type": {"key": "/type/edition"}, "authors": [{"key": "/authors/OL215921A"}], "isbn_13": ["9798596446548"], "languages": [{"key": "/languages/eng"}], "pagination": "306", "publish_date": "2021", "publishers": ["Independently Published"], "source_records": ["bwb:9798596446548"], "title": "Mystery of a Hansom Cab", "weight": "0.527", "full_title": "Mystery of a Hansom Cab", "works": [{"key": "/works/OL1798912W"}], "key": "/books/OL42344957M", "latest_revision": 3, "revision": 3, "created": {"type": "/type/datetime", "value": "2022-12-01T16:29:16.736754"}, "last_modified": {"type": "/type/datetime", "value": "2023-09-22T20:45:30.243427"}}, {"type": {"key": "/type/edition"}, "title": "The Mystery of a Hansom Cab", "authors": [{"key": "/authors/OL9216769A"}], "publish_date": "Jan 31, 2008", "source_records": ["amazon:1601121822"], "publishers": ["Babblebooks"], "isbn_10": ["1601121822"], "isbn_13": ["9781601121820"], "physical_format": "audio cd", "full_title": "The Mystery of a Hansom Cab", "covers": [12389890], "works": [{"key": "/works/OL1798912W"}], "key": "/books/OL35690727M", "latest_revision": 2, "revision": 2, "created": {"type": "/type/datetime", "value": "2021-12-01T17:55:52.326810"}, "last_modified": {"type": "/type/datetime", "value": "2023-09-22T20:45:30.243427"}}, {"type": {"key": "/type/edition"}, "authors": [{"key": "/authors/OL9216769A"}], "isbn_13": ["9781480442658"], "languages": [{"key": "/languages/eng"}], "pagination": "250", "publish_date": "2015", "publishers": ["MysteriousPress.com"], "source_records": ["bwb:9781480442658"], "subjects": ["Fiction, mystery & detective, general", "Australia, fiction"], "title": "Mystery of a Hansom Cab", "full_title": "Mystery of a Hansom Cab", "works": [{"key": "/works/OL1798912W"}], "key": "/books/OL36217321M", "latest_revision": 2, "revision": 2, "created": {"type": "/type/datetime", "value": "2021-12-29T10:42:37.333740"}, "last_modified": {"type": "/type/datetime", "value": "2023-09-22T20:45:30.243427"}}, {"type": {"key": "/type/edition"}, "authors": [{"key": "/authors/OL9216769A"}], "isbn_13": ["9798493925931"], "languages": [{"key": "/languages/eng"}], "pagination": "344", "publish_date": "2021", "publishers": ["Independently Published"], "source_records": ["bwb:9798493925931"], "title": "Mystery of a Hansom Cab", "weight": "0.514", "subtitle": "Illustrated", "full_title": "Mystery of a Hansom Cab Illustrated", "works": [{"key": "/works/OL1798912W"}], "key": "/books/OL36857329M", "latest_revision": 2, "revision": 2, "created": {"type": "/type/datetime", "value": "2022-01-28T14:29:12.926935"}, "last_modified": {"type": "/type/datetime", "value": "2023-09-22T20:45:30.243427"}}, {"type": {"key": "/type/edition"}, "authors": [{"key": "/authors/OL9216769A"}], "description": {"type": "/type/text", "value": "<p><i>The Mystery of a Hansom Cab</i>, published in 1886, was the first novel by <a href=\"https://standardebooks.org/ebooks/fergus-hume\">Fergus Hume</a>. It begins with a sensational murder, as the body of a dead man is discovered in a hansom cab by the driver. Set in Melbourne, Australia, it presents an engaging story of crime and detection, with several unexpected twists and turns. It also gives a clear and interesting portrait of the colonial city at the peak of its 19th Century prosperity following a gold rush, a time when it was known as \u201cMarvellous Melbourne.\u201d The novel contrasts the comfortable lives of the rich and well-connected of the colony with the misery of those living in the noisome slums in the back-streets of the city.</p>\r\n\t\t\t<p>The novel, originally published in serial form in a local newspaper, achieved some initial local success when it was first released in book form, but the author then sold the rights to a British company.</p>\r\n\t\t\t<p>After warm initial reviews in England <i>The Mystery of a Hansom Cab</i> became not merely a best-seller but what today we would call a \u201cblockbuster\u201d in the United Kingdom, its English-speaking colonies and the United States. It was the best-selling mystery novel of the Victorian era, and apparently was part of the inspiration for Conan Doyle to begin writing his Sherlock Holmes stories.</p>\r\n\t\t\t<p>Fergus Hume eventually left Australia and returned to England. Though little-known today, after the success of <i>The Mystery of a Hansom Cab</i> Hume went on to write more than a hundred additional novels in the crime genre, as well as several plays.</p>"}, "identifiers": {"standard_ebooks": ["fergus-hume/the-mystery-of-a-hansom-cab"]}, "languages": [{"key": "/languages/eng"}], "publish_date": "2019", "publishers": ["Standard Ebooks"], "source_records": ["standard_ebooks:fergus-hume/the-mystery-of-a-hansom-cab"], "subjects": ["Fiction", "Detective and mystery stories, English"], "title": "The Mystery of a Hansom Cab", "full_title": "The Mystery of a Hansom Cab", "covers": [12622067], "works": [{"key": "/works/OL1798912W"}], "key": "/books/OL37044752M", "classifications": {}, "latest_revision": 3, "revision": 3, "created": {"type": "/type/datetime", "value": "2022-02-09T00:05:24.861648"}, "last_modified": {"type": "/type/datetime", "value": "2023-09-22T20:45:30.243427"}}, {"type": {"key": "/type/edition"}, "authors": [{"key": "/authors/OL9216769A"}], "isbn_13": ["9780486822280"], "languages": [{"key": "/languages/eng"}], "pagination": "256", "publish_date": "2017", "publishers": ["Dover Publications, Incorporated"], "source_records": ["bwb:9780486822280"], "subjects": ["Fiction, mystery & detective, general", "Australia, fiction"], "title": "Mystery of a Hansom Cab", "weight": "0.328", "full_title": "Mystery of a Hansom Cab", "works": [{"key": "/works/OL1798912W"}], "key": "/books/OL38380376M", "latest_revision": 2, "revision": 2, "created": {"type": "/type/datetime", "value": "2022-06-18T17:10:32.401223"}, "last_modified": {"type": 