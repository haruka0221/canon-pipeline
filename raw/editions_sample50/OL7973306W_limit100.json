56:55.358049"}, "last_modified": {"type": "/type/datetime", "value": "2022-03-19T16:58:55.207563"}}, {"works": [{"key": "/works/OL7973306W"}], "title": "Present at a Hanging and Other Ghost Stories", "publishers": ["LibriVox"], "publish_date": "2006-02-06", "key": "/books/OL37758997M", "type": {"key": "/type/edition"}, "identifiers": {"librivox": ["present-at-a-hanging-by-ambrose-bierce"]}, "covers": [12670418], "ocaid": "hanging_librivox", "classifications": {}, "table_of_contents": [{"level": 0, "label": "", "title": "The Ways of Ghosts: Stories of encounters with the ghosts of the dead and dying. The spirits of the dead reach out to the living, to pass on a message or to pursue a killer.", "pagenum": ""}, {"level": 0, "label": "", "title": "Contents (with beginning time):", "pagenum": ""}, {"level": 0, "label": "", "title": "Present at a Hanging (02:06)", "pagenum": ""}, {"level": 0, "label": "", "title": "A Cold Greeting (07:07)", "pagenum": ""}, {"level": 0, "label": "", "title": "A Wireless Message (11:15)", "pagenum": ""}, {"level": 0, "label": "", "title": "An Arrest (17:04)", "pagenum": ""}, {"level": 0, "label": "", "title": "Soldier Folk: Oddities of death and life; from a man who finds that his death is uncertain, through the effects of war on the family, duty that survives death, to the memory of revenge.", "pagenum": ""}, {"level": 0, "label": "", "title": "Contents (with beginning time):", "pagenum": ""}, {"level": 0, "label": "", "title": "A Man with Two Lives (00:31)", "pagenum": ""}, {"level": 0, "label": "", "title": "Three and One are One (06:23)", "pagenum": ""}, {"level": 0, "label": "", "title": "A Baffled Ambuscade (14:18)", "pagenum": ""}, {"level": 0, "label": "", "title": "Two Military Executions (19:45)", "pagenum": ""}, {"level": 0, "label": "", "title": "Some Haunted Houses - Part One: Encounters of the living with the spirits of the dead who have been bound into buildings. An old man revenges himself; a journalist investigates a haunted house; and the quivering vine that tangles the face of a deserted home.", "pagenum": ""}, {"level": 0, "label": "", "title": "Contents (with beginning time):", "pagenum": ""}, {"level": 0, "label": "", "title": "The Isle of Pines (00:31)", "pagenum": ""}, {"level": 0, "label": "", "title": "A Fruitless Assignment (10:39)", "pagenum": ""}, {"level": 0, "label": "", "title": "A Vine on a House (17:54)", "pagenum": ""}, {"level": 0, "label": "", "title": "Some Haunted Houses - Part Two: Houses where the living are never seen again, memories of the mortuary live on, and a murdered man wanders through.", "pagenum": ""}, {"level": 0, "label": "", "title": "Contents (with beginning time):", "pagenum": ""}, {"level": 0, "label": "", "title": "At Old Man Eckert\u2019s (00:30)", "pagenum": ""}, {"level": 0, "label": "", "title": "The Spook House (06:36)", "pagenum": ""}, {"level": 0, "label": "", "title": "The Other Lodgers (16:04)", "pagenum": ""}, {"level": 0, "label": "", "title": "The Thing at Nolan (21:50)", "pagenum": ""}, {"level": 0, "label": "", "title": "Mysterious Disappearances: Three short tales of men who have vanished living their ordinary lives, sometimes in full view of witnesses; plus a short, probably fictional, description of a theory to partly explain these events.", "pagenum": ""}, {"level": 0, "label": "", "title": "Contents (with beginning time):", "pagenum": ""}, {"level": 0, "label": "", "title": "The Difficulty of Crossing a Field (00:32)", "pagenum": ""}, {"level": 0, "label": "", "title": "An Unfinished Race (05:18)", "pagenum": ""}, {"level": 0, "label": "", "title": "Charles Ashmore\u2019s Trail (07:50)", "pagenum": ""}, {"level": 0, "label": "", "title": "Science to the Front (12:23)", "pagenum": ""}], "languages": [{"key": "/languages/eng"}], "latest_revision": 3, "revision": 3, "created": {"type": "/type/datetime", "value": "2022-03-15T06:24:50.755790"}, "last_modified": {"type": "/type/datetime", "value": "2022-03-15T06:26:31.605038"}}, {"